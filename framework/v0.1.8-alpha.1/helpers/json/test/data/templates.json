{
  "_common": {
    "layout": "${}/html/layout.html",
    "noLayout": "${}/framework/v${}/core/asset/html/nolayout.html",
    "templates": "${}", // only if hasView()
    "html": "${}/html",  // only if hasView()
    "theme": "default_theme", // only if hasView()
    "forms": "${}/forms",
    "handlers": "${}/handlers",
    "routeNameAsFilenameEnabled": true,
    "ginaEnabled": true, // set to false, this will exclude gina assets from being loaded
    "http-metas": {
      "content-type": "text/html"
    },
    /** stylesheets definition */
    "stylesheets": [
      {
        "name"    : "gina",
        "media"   : "screen",
        "rel"     : "stylesheet",
        "type"    : "text/css",
        "url"     : "/js/vendor/gina/gina.min.css"
      }
    ],
    "javascriptsDeferEnabled": true, // will place scripts in defer mode in the head by default. If false, will place in the footer
    /**
    * Javascript definition
    */
    "javascripts": [
      {
        "name"    : "gina",
        "type"   : "text/javascript",
        "url"     : "/js/vendor/gina/gina.min.js"
      }
    ],
    "_pluginLoader": "{src:${}/framework/v${}/core/asset/plugin/src/vendor/gina/utils/loader.js}",
    "pluginLoader": "{src:${}/framework/v${}/core/asset/plugin/dist/vendor/gina/js/gina.onload.min.js}"
  }
}