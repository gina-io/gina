{
    "frameworks": {
        "${}": [ "${}" ]
    },
    "def_framework": "${}",
    "def_prefix": {
        "${}": "${}"
    },
    "def_global_mode": {
        "${}": "${}"
    },
    "archs": {
        "${}": [
            "arm",
            "arm64",
            "x64",
            "amd64"
        ]
    },
    "def_arch": {
        "${}": "x64"
    },
    "platforms": {
        "${}": [
            "darwin",
            "linux",
            "win32",
            "freebsd",
            "openbsd",
            "sunos",
            "aix"
        ]
    },
    "def_platform": {
        "${}": "linux"
    },
    "scopes": {
        "${}": [
            "local",
            "production"
        ]
    },
    "def_scope": {
        "${}": "local"
    },
    "local_scope": {
        "${}": "local"
    },
    "production_scope": {
        "${}": "production"
    },
    "envs": {
        "${}": [ "dev", "prod" ]
    },
    "def_env": {
      "${}": "dev"
    },
    "dev_env": {
        "${}": "dev"
    },

    "protocols": {
        "_comment": "e.g.:  http/1.1, http/2.0, net",
        "${}": [  "http/1.1", "http/2.0" ]
    },
    "def_protocol": {
        "${}": "http/1.1"
    },
    "schemes": {
        "_comment": "e.g.:  http, https",
        "${}": [  "http", "https" ]
    },
    "def_scheme": {
        "${}": "http"
    },
    "cultures": {
        "_comment": "e.g.:  en_US, fr_FR etc. available for the framework then used to translate the admin dashboard",
        "${}": [  "en_CM", "fr_CM" ]
    },
    "def_culture": {
        "${}": "en_CM"
    },
    "def_iso_short": {
        "${}": "cm"
    },
    "def_timezone": {
        "${}": "Africa/Douala"
    },
    "def_date": {
        "${}": "yyyy/mm/dd"
    },
    "log_levels": {
        "_comment": "hierarchy",
        "${}": [  "trace", "debug", "info", "warn", "error", "fatal" ]
    },
    "def_log_level": {
        "${}": "info"
    }
}